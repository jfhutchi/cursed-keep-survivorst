; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Cursed Keep Survivors"
config/description="Original dark-fantasy bullet-heaven survivor game. You are the last Wardkeeper trapped in a living, cursed fortress."
config/version="0.1.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6")
config/icon="res://icon.svg"

[autoload]

GameEvents="*res://scripts/core/game_events.gd"
SaveSystem="*res://scripts/core/save_system.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
GameData="*res://scripts/core/game_data.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[audio]

; Web exports default to the "Sample" (Web Audio buffer) playback path, which
; leaks/crashes under heavy SFX with per-play pitch_scale on Chrome
; (godotengine/godot#96068, #115560). Force the AudioWorklet "Stream" path.
general/default_playback_type.web=1

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=4

[dotnet]

project/assembly_name="CursedKeep"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg")

